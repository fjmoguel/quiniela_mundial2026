generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  predictions          Prediction[]
  groupPredictions     GroupPrediction[]
  knockoutBracketPicks KnockoutBracketPick[]
}

model Team {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String @unique
  flag        String
  groupLetter String
  fifaRank    Int?

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  stage       String  // "group" | "r32" | "r16" | "qf" | "sf" | "final" | "third_place"
  groupLetter String?
  matchday    Int?
  label       String?
  kickoff     DateTime
  venue       String?

  homeTeamId String? @db.ObjectId
  awayTeamId String? @db.ObjectId
  homeTeam   Team?   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore        Int?
  awayScore        Int?
  wentToExtraTime  Boolean   @default(false)
  wentToPenalties  Boolean   @default(false)
  resultRecordedAt DateTime?
  resultSource     String?   // "manual" | "api" | null — manual takes precedence over auto-sync

  predictions Prediction[]
}

model Prediction {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  userId        String @db.ObjectId
  matchId       String @db.ObjectId

  predHomeScore Int
  predAwayScore Int
  predExtraTime Boolean @default(false)
  predPenalties Boolean @default(false)

  pointsAwarded Int       @default(0)
  scoredAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model GroupPrediction {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @db.ObjectId
  groupLetter String

  firstPlaceTeamId  String @db.ObjectId
  secondPlaceTeamId String @db.ObjectId
  thirdPlaceTeamId  String @db.ObjectId
  fourthPlaceTeamId String @db.ObjectId

  pointsAwarded Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupLetter])
}

model KnockoutBracketPick {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  userId  String @db.ObjectId
  slotKey String
  teamId  String @db.ObjectId

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slotKey])
}
